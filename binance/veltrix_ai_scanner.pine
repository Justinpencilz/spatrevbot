//@version=6
indicator("VELTRIX AI SCANNER 2.0.0", overlay=true)

// === Inputs ===
fastMA = input.int(9, "Fast MA", minval=1)
slowMA = input.int(21, "Slow MA", minval=1)
src = input.source(close, "Source")
higherTF = input.int(60, "Higher Timeframe (in minutes)")
swingLength = input.int(10, "Swing Detection Length", minval=5)
pivotLength = input.int(5, "Pivot Length for Swing Detection", minval=2)

// === MAs ===
fast = ta.sma(src, fastMA)
slow = ta.sma(src, slowMA)

// === FIXED: Remove lookahead to prevent repainting ===
fastHigherTF = request.security(syminfo.tickerid, str.tostring(higherTF), ta.sma(close, fastMA))
slowHigherTF = request.security(syminfo.tickerid, str.tostring(higherTF), ta.sma(close, slowMA))

// === FIXED: More stable swing detection using confirmed pivot points ===
pivotHigh = ta.pivothigh(high, pivotLength, pivotLength)
pivotLow = ta.pivotlow(low, pivotLength, pivotLength)

// Store last confirmed swing levels
var float lastSwingHigh = na
var float lastSwingLow = na

// Update swing levels only when new confirmed pivots are found
if not na(pivotHigh)
    lastSwingHigh := pivotHigh
if not na(pivotLow)
    lastSwingLow := pivotLow

// Fallback to simple lookback if no pivots found yet
swingHigh = na(lastSwingHigh) ? ta.highest(high[1], swingLength)[1] : lastSwingHigh
swingLow = na(lastSwingLow) ? ta.lowest(low[1], swingLength)[1] : lastSwingLow

// === FIXED: Use previous bar's close for signal confirmation ===
buySignal = ta.crossover(fast, slow) and fastHigherTF > slowHigherTF and barstate.isconfirmed
sellSignal = ta.crossunder(fast, slow) and fastHigherTF < slowHigherTF and barstate.isconfirmed

// === Risk-Reward ===
rr1 = input.float(1.0, "Risk Reward Ratio 1", minval=0.1, step=0.1)
rr2 = input.float(2.0, "Risk Reward Ratio 2", minval=0.1, step=0.1)
lineLength = input.int(60, "Line Length", minval=10)

// === State ===
var bool longActive = false
var bool shortActive = false
var float slLevel = na
var float tp1Level = na
var float tp2Level = na
var float entryLevel = na

// === Last Trade Tracking ===
var int currentTradeTime = na
var string currentTradeType = na
var string currentTradeDate = na

// === Labels & Lines ===
var label buyLabel = na
var label sellLabel = na
var label slLabel = na
var label tp1Label = na
var label tp2Label = na
var label entryLabel = na
var line slLine = na
var line tp1Line = na
var line tp2Line = na
var line entryLine = na

// === Total Counters ===
var int wins = 0
var int losses = 0

// === Daily Counters ===
var int dayWins = 0
var int dayLosses = 0

// Get current real-time date for comparison
currentYear = year(timenow)
currentMonth = month(timenow)
currentDay = dayofmonth(timenow)
currentDayID = currentDay + currentMonth * 100 + currentYear * 10000

// Get bar's date
barYear = year(time)
barMonth = month(time)
barDay = dayofmonth(time)
barDayID = barDay + barMonth * 100 + barYear * 10000

// Only count if bar is from the actual current day AND market is open
isToday = (barDayID == currentDayID) and (barstate.isconfirmed or barstate.islast)

var int lastDayID = na
if na(lastDayID)
    lastDayID := currentDayID
if currentDayID != lastDayID
    dayWins := 0
    dayLosses := 0
    lastDayID := currentDayID

dayTotal = dayWins + dayLosses
dayWinRate = dayTotal > 0 ? (dayWins / dayTotal) * 100 : na

// === Weekly Counters ===
var int weekWins = 0
var int weekLosses = 0

// Get current week info
currentWeekYear = year(timenow)
currentWeekNum = weekofyear(timenow)
currentWeekID = currentWeekYear * 100 + currentWeekNum

// Get bar's week info
barWeekYear = year(time)
barWeekNum = weekofyear(time)
barWeekID = barWeekYear * 100 + barWeekNum

// Only count if bar is from current week AND confirmed
isWeek = (barWeekID == currentWeekID) and (barstate.isconfirmed or barstate.islast)

var int lastWeekID = na
if na(lastWeekID)
    lastWeekID := currentWeekID
if currentWeekID != lastWeekID
    weekWins := 0
    weekLosses := 0
    lastWeekID := currentWeekID

weekTotal = weekWins + weekLosses
weekWinRate = weekTotal > 0 ? (weekWins / weekTotal) * 100 : na

// === Monthly Counters ===
var int monthWins = 0
var int monthLosses = 0

// Get current month info
currentMonthYear = year(timenow)
currentMonthNum = month(timenow)
currentMonthID = currentMonthYear * 100 + currentMonthNum

// Get bar's month info
barMonthYear = year(time)
barMonthNum = month(time)
barMonthID = barMonthYear * 100 + barMonthNum

// Only count if bar is from current month AND confirmed
isMonth = (barMonthID == currentMonthID) and (barstate.isconfirmed or barstate.islast)

var int lastMonthID = na
if na(lastMonthID)
    lastMonthID := currentMonthID
if currentMonthID != lastMonthID
    monthWins := 0
    monthLosses := 0
    lastMonthID := currentMonthID

monthTotal = monthWins + monthLosses
monthWinRate = monthTotal > 0 ? (monthWins / monthTotal) * 100 : na

// === Cleanup old objects ===
if (buySignal or sellSignal)
    label.delete(buyLabel)
    label.delete(sellLabel)
    label.delete(slLabel)
    label.delete(tp1Label)
    label.delete(tp2Label)
    label.delete(entryLabel)
    line.delete(slLine)
    line.delete(tp1Line)
    line.delete(tp2Line)
    line.delete(entryLine)

// === FIXED: Validate swing levels before using them ===
validSwingLow = not na(swingLow) and swingLow > 0
validSwingHigh = not na(swingHigh) and swingHigh > 0

// === BUY LOGIC ===
if (buySignal and validSwingLow)
    float entry = close
    float sl = swingLow
    float riskAmount = entry - sl
    
    // Only proceed if risk is reasonable (positive and not too large)
    if riskAmount > 0 and riskAmount < entry * 0.1  // Max 10% risk
        float tp1 = entry + riskAmount * rr1
        float tp2 = entry + riskAmount * rr2

        longActive := true
        shortActive := false
        entryLevel := entry
        slLevel := sl
        tp1Level := tp1
        tp2Level := tp2

        // Record current active trade info
        currentTradeTime := time_close
        currentTradeType := "SELL"
        currentTradeDate := str.tostring(dayofmonth(time_close)) + "/" + str.tostring(month(time_close)) + "/" + str.tostring(year(time_close)) + " " + str.tostring(hour(time_close)) + ":" + (minute(time_close) < 10 ? "0" + str.tostring(minute(time_close)) : str.tostring(minute(time_close))) + " UTC"

        // Record current active trade info
        currentTradeTime := time_close
        currentTradeType := "BUY"
        currentTradeDate := str.tostring(dayofmonth(time_close)) + "/" + str.tostring(month(time_close)) + "/" + str.tostring(year(time_close)) + " " + str.tostring(hour(time_close)) + ":" + (minute(time_close) < 10 ? "0" + str.tostring(minute(time_close)) : str.tostring(minute(time_close))) + " UTC"

        buyLabel := label.new(bar_index, low - syminfo.mintick * 10, "BUYCRT-IOF/SMC", style=label.style_label_up, color=color.green, textcolor=color.black)
        entryLine := line.new(bar_index, entry, bar_index + lineLength, entry, color=color.black, width=2)
        slLine := line.new(bar_index, sl, bar_index + lineLength, sl, color=color.red, style=line.style_solid, width=4)
        tp1Line := line.new(bar_index, tp1, bar_index + lineLength, tp1, color=color.green, style=line.style_solid, width=4)
        tp2Line := line.new(bar_index, tp2, bar_index + lineLength, tp2, color=color.green, style=line.style_solid, width=4)

        entryLabel := label.new(bar_index + lineLength + 2, entry, "BUY: " + str.tostring(entry, format.mintick), style=label.style_label_right, color=color.green, textcolor=color.black)
        slLabel := label.new(bar_index + lineLength + 2, sl, "SL: " + str.tostring(sl, format.mintick), style=label.style_label_center, color=color.red, textcolor=color.white)
        tp1Label := label.new(bar_index + lineLength + 2, tp1, "TP1: " + str.tostring(tp1, format.mintick), style=label.style_label_center, color=color.lime, textcolor=color.black)
        tp2Label := label.new(bar_index + lineLength + 2, tp2, "TP2: " + str.tostring(tp2, format.mintick), style=label.style_label_center, color=color.lime, textcolor=color.black)

        alert("Buy Signal at " + str.tostring(entry) + " | SL: " + str.tostring(sl) + " | TP1: " + str.tostring(tp1), alert.freq_once_per_bar_close)

// === SELL LOGIC ===
if (sellSignal and validSwingHigh)
    float entry = close
    float sl = swingHigh
    float riskAmount = sl - entry
    
    // Only proceed if risk is reasonable (positive and not too large)
    if riskAmount > 0 and riskAmount < entry * 0.1  // Max 10% risk
        float tp1 = entry - riskAmount * rr1
        float tp2 = entry - riskAmount * rr2

        shortActive := true
        longActive := false
        entryLevel := entry
        slLevel := sl
        tp1Level := tp1
        tp2Level := tp2

        sellLabel := label.new(bar_index, high + syminfo.mintick * 10, "SELLCRT-IOF/SMC", style=label.style_label_down, color=color.red, textcolor=color.white)
        entryLine := line.new(bar_index, entry, bar_index + lineLength, entry, color=color.black, width=2)
        slLine := line.new(bar_index, sl, bar_index + lineLength, sl, color=color.red, style=line.style_solid, width=4)
        tp1Line := line.new(bar_index, tp1, bar_index + lineLength, tp1, color=color.green, style=line.style_solid, width=4)
        tp2Line := line.new(bar_index, tp2, bar_index + lineLength, tp2, color=color.green, style=line.style_solid, width=4)

        entryLabel := label.new(bar_index + lineLength + 2, entry, "SELL: " + str.tostring(entry, format.mintick), style=label.style_label_right, color=color.red, textcolor=color.white)
        slLabel := label.new(bar_index + lineLength + 2, sl, "SL: " + str.tostring(sl, format.mintick), style=label.style_label_center, color=color.red, textcolor=color.white)
        tp1Label := label.new(bar_index + lineLength + 2, tp1, "TP1: " + str.tostring(tp1, format.mintick), style=label.style_label_center, color=color.lime, textcolor=color.black)
        tp2Label := label.new(bar_index + lineLength + 2, tp2, "TP2: " + str.tostring(tp2, format.mintick), style=label.style_label_center, color=color.lime, textcolor=color.black)

        alert("Sell Signal at " + str.tostring(entry) + " | SL: " + str.tostring(sl) + " | TP1: " + str.tostring(tp1), alert.freq_once_per_bar_close)

// === FIXED: Use confirmed close prices for TP/SL hits ===
if longActive and not na(tp1Level) and not na(tp2Level) and not na(slLevel)
    if close >= tp1Level and close[1] < tp1Level  // First time hitting TP1
        label.set_text(tp1Label, "TP1: " + str.tostring(tp1Level, format.mintick) + " ✅")
        wins += 1
        if isToday
            dayWins += 1
        if isWeek
            weekWins += 1
        if isMonth
            monthWins += 1

    if close >= tp2Level and close[1] < tp2Level  // First time hitting TP2
        label.set_text(tp2Label, "TP2: " + str.tostring(tp2Level, format.mintick) + " ✅")
        wins += 1
        if isToday
            dayWins += 1
        if isWeek
            weekWins += 1
        if isMonth
            monthWins += 1
        longActive := false
        // Clear current trade info when trade closes
        currentTradeType := na
        currentTradeDate := na

    if close <= slLevel and close[1] > slLevel  // First time hitting SL
        label.set_text(slLabel, "SL: " + str.tostring(slLevel, format.mintick) + " ❌")
        losses += 1
        if isToday
            dayLosses += 1
        if isWeek
            weekLosses += 1
        if isMonth
            monthLosses += 1
        longActive := false
        // Clear current trade info when trade closes
        currentTradeType := na
        currentTradeDate := na

if shortActive and not na(tp1Level) and not na(tp2Level) and not na(slLevel)
    if close <= tp1Level and close[1] > tp1Level  // First time hitting TP1
        label.set_text(tp1Label, "TP1: " + str.tostring(tp1Level, format.mintick) + " ✅")
        wins += 1
        if isToday
            dayWins += 1
        if isWeek
            weekWins += 1
        if isMonth
            monthWins += 1

    if close <= tp2Level and close[1] > tp2Level  // First time hitting TP2
        label.set_text(tp2Label, "TP2: " + str.tostring(tp2Level, format.mintick) + " ✅")
        wins += 1
        if isToday
            dayWins += 1
        if isWeek
            weekWins += 1
        if isMonth
            monthWins += 1
        shortActive := false
        // Clear current trade info when trade closes
        currentTradeType := na
        currentTradeDate := na

    if close >= slLevel and close[1] < slLevel  // First time hitting SL
        label.set_text(slLabel, "SL: " + str.tostring(slLevel, format.mintick) + " ❌")
        losses += 1
        if isToday
            dayLosses += 1
        if isWeek
            weekLosses += 1
        if isMonth
            monthLosses += 1
        shortActive := false
        // Clear current trade info when trade closes
        currentTradeType := na
        currentTradeDate := na
        
// === Complete Horizontal Dashboard (4x9 - All Data Visible) ===
var table dash = table.new(position.bottom_center, 4, 9)

if barstate.islast or bar_index % 10 == 0 or buySignal or sellSignal
    totalTrades = wins + losses
    totalWinRate = totalTrades > 0 ? (wins / totalTrades) * 100 : na
    dayTotal = dayWins + dayLosses
    dayWinRate = dayTotal > 0 ? (dayWins / dayTotal) * 100 : na
    weekTotal = weekWins + weekLosses
    weekWinRate = weekTotal > 0 ? (weekWins / weekTotal) * 100 : na
    monthTotal = monthWins + monthLosses
    monthWinRate = monthTotal > 0 ? (monthWins / monthTotal) * 100 : na
    
    // Color calculations
    totalWinColor = na(totalWinRate) ? #666666 : totalWinRate >= 70 ? #00ff88 : totalWinRate >= 50 ? #ffaa00 : #ff4444
    dayWinColor = na(dayWinRate) ? #666666 : dayWinRate >= 70 ? #00ff88 : dayWinRate >= 50 ? #ffaa00 : #ff4444
    weekWinColor = na(weekWinRate) ? #666666 : weekWinRate >= 70 ? #00ff88 : weekWinRate >= 50 ? #ffaa00 : #ff4444
    monthWinColor = na(monthWinRate) ? #666666 : monthWinRate >= 70 ? #00ff88 : monthWinRate >= 50 ? #ffaa00 : #ff4444
    
    tradeStatus = longActive ? "🟢 LONG" : shortActive ? "🔴 SHORT" : "⚪ NO TRADE"
    statusBgColor = longActive ? #00cc44 : shortActive ? #ff3333 : #555555
    
    // === ROW 0: HEADER ===
    table.cell(dash, 0, 0, "⚡ VELTRIX AI", bgcolor=#0066ff, text_color=color.white, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 1, 0, "SCANNER 2.0", bgcolor=#0044cc, text_color=color.white, text_size=size.small, text_halign=text.align_center)
    table.cell(dash, 2, 0, "", bgcolor=#0044cc, text_color=color.white)
    table.cell(dash, 3, 0, "", bgcolor=#0044cc, text_color=color.white)
    
    // === ROW 1: TOTAL SECTION HEADER ===
    table.cell(dash, 0, 1, "📊 TOTAL STATS", bgcolor=#2d2d2d, text_color=#00ff88, text_size=size.small)
    table.cell(dash, 1, 1, "", bgcolor=#2d2d2d, text_color=color.white)
    table.cell(dash, 2, 1, "", bgcolor=#2d2d2d, text_color=color.white)
    table.cell(dash, 3, 1, "", bgcolor=#2d2d2d, text_color=color.white)
    
    // === ROW 2: TOTAL WINS & LOSSES ===
    table.cell(dash, 0, 2, "Total Wins", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(wins), bgcolor=#00cc66, text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 2, "Total Losses", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 2, str.tostring(losses), bgcolor=#ff3333, text_color=color.white, text_size=size.small)
    
    // === ROW 3: TOTAL WIN RATE ===
    table.cell(dash, 0, 3, "Total Win %", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, na(totalWinRate) ? "N/A" : str.tostring(totalWinRate, "#.##") + "%", bgcolor=totalWinColor, text_color=color.black, text_size=size.small)
    table.cell(dash, 2, 3, "", bgcolor=#1a1a1a, text_color=color.white)
    table.cell(dash, 3, 3, "", bgcolor=#1a1a1a, text_color=color.white)
    
    // === ROW 4: DAILY SECTION HEADER ===
    table.cell(dash, 0, 4, "📅 TODAY", bgcolor=#2d2d2d, text_color=#00ccff, text_size=size.small)
    table.cell(dash, 1, 4, "", bgcolor=#2d2d2d, text_color=color.white)
    table.cell(dash, 2, 4, "", bgcolor=#2d2d2d, text_color=color.white)
    table.cell(dash, 3, 4, "", bgcolor=#2d2d2d, text_color=color.white)
    
    // === ROW 5: DAILY WINS & LOSSES ===
    table.cell(dash, 0, 5, "Day Wins", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(dayWins), bgcolor=#00aa55, text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 5, "Day Losses", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 5, str.tostring(dayLosses), bgcolor=#cc2222, text_color=color.white, text_size=size.small)
    
    // === ROW 6: DAILY WIN RATE ===
    table.cell(dash, 0, 6, "Day Win %", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, na(dayWinRate) ? "N/A" : str.tostring(dayWinRate, "#.##") + "%", bgcolor=dayWinColor, text_color=color.black, text_size=size.small)
    table.cell(dash, 2, 6, "", bgcolor=#1a1a1a, text_color=color.white)
    table.cell(dash, 3, 6, "", bgcolor=#1a1a1a, text_color=color.white)
    
    // === ROW 7: WEEKLY & MONTHLY ===
    table.cell(dash, 0, 7, "📆 WEEK", bgcolor=#2d2d2d, text_color=#ff6600, text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(weekWins) + "W/" + str.tostring(weekLosses) + "L", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 7, "🗓 MONTH", bgcolor=#2d2d2d, text_color=#ff00ff, text_size=size.small)
    table.cell(dash, 3, 7, str.tostring(monthWins) + "W/" + str.tostring(monthLosses) + "L", bgcolor=#1a1a1a, text_color=color.white, text_size=size.small)
    
    // === ROW 8: STATUS & SIGNAL ===
    table.cell(dash, 0, 8, "STATUS", bgcolor=#2d2d2d, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 8, tradeStatus, bgcolor=statusBgColor, text_color=color.white, text_size=size.small)
    
    signalText = (longActive or shortActive) and not na(currentTradeType) ? currentTradeType : "None"
    table.cell(dash, 2, 8, "SIGNAL", bgcolor=#2d2d2d, text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 8, signalText, bgcolor=#1a1a1a, text_color=#00ddff, text_size=size.small)

// === Telegram Banner ===
var table telegramTable = table.new(position.top_center, 1, 1)
if barstate.islast
    table.cell(telegramTable, 0, 0, "📱 SPATREV | 🌐 WWW.SPATREV.COM WhatsApp: +2348108980778", bgcolor=#0066ff, text_color=color.white, text_size=size.small)